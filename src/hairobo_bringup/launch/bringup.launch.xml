<?xml version="1.0" encoding="UTF-8"?>
<launch>

    <!-- 1. teleop -->
    <include file="$(find-pkg-share hairobo_teleop)/launch/teleop.launch.py" />

    <!-- 2. rosbridge -->
    <include file="$(find-pkg-share rosbridge_server)/launch/rosbridge_websocket_launch.xml">
        <arg name="address" value="0.0.0.0"/>
    </include>

    <!-- 3. WebUI ディレクトリのパス -->
    <let name="webui_dir" value="$(find-pkg-share hairobo_bringup)/../../../../hairobo-webui"/>

    <!-- 4. Vite 開発サーバー -->
    <!-- nvm 経由の npm はフルパスで指定する必要があります -->
    <!-- PATH に node バイナリのディレクトリを追加して、正しいバージョンの node が使われるようにします -->
    <executable cmd="/home/amuratakamitamu/.nvm/versions/node/v22.18.0/bin/npm run dev:vite" cwd="$(var webui_dir)" output="screen">
        <env name="PATH" value="/home/amuratakamitamu/.nvm/versions/node/v22.18.0/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin" />
        <env name="FORCE_COLOR" value="1" />
    </executable>

    <!-- 5. Timer サーバー -->
    <executable cmd="/home/amuratakamitamu/.nvm/versions/node/v22.18.0/bin/npm run dev:server" cwd="$(var webui_dir)" output="screen">
        <env name="PATH" value="/home/amuratakamitamu/.nvm/versions/node/v22.18.0/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin" />
        <env name="FORCE_COLOR" value="1" />
    </executable>

</launch>
