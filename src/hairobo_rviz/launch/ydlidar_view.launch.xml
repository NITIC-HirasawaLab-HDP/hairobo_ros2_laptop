<?xml version="1.0"?>
<launch>
  <!-- YDLiDAR用RViz2起動ファイル -->
  
  <!-- Static TF: base_link -> laser_frame -->
  <node pkg="tf2_ros" exec="static_transform_publisher" name="static_tf_pub_laser"
        args="0 0 0.02 0 0 0 1 base_link laser_frame" />
  
  <!-- RViz2 -->
  <node pkg="rviz2" exec="rviz2" name="rviz2"
        args="-d $(find-pkg-share hairobo_rviz)/config/slam.rviz" />
</launch>
