# 操作モード切り替えサービス

# リクエスト
uint8 MODE_PARENT = 0      # 親機操作モード
uint8 MODE_CHILD = 1       # 子機操作モード  
uint8 MODE_IDLE = 2        # アイドルモード（操作無効）
uint8 MODE_EMERGENCY = 3   # 緊急停止モード

uint8 target_mode          # 設定したい操作モード
string reason              # モード切り替えの理由（ログ用）
bool force_change          # 強制切り替えフラグ（緊急時用）

---

# レスポンス
bool success               # 切り替え成功/失敗
string message             # 結果メッセージ
uint8 current_mode         # 切り替え後の現在モード
builtin_interfaces/Time change_time  # 切り替え実行時刻
